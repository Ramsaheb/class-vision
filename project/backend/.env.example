# ─── CORIS - Classroom Observation System Environment Variables ───

# 🚀 Server Configuration
# 1 = Start processing automatically on server boot, 0 = Wait for manual trigger
AUTO_START_PROCESSING=1

# 📸 Camera Processing Frame-rate
# Process every Nth frame to balance speed and accuracy (1 = process every frame, 5 = process every 5th frame)
PROCESS_EVERY_N_FRAMES=1

# 🧠 YOLO Model Settings
# Face detection confidence threshold (0.0 to 1.0)
YOLO_CONF=0.30
# Non-Maximum Suppression (NMS) IOU threshold for filtering overlapping boxes
NMS_IOU_THRESHOLD=0.45
# Enhanced pipeline specific YOLO confidence
ENHANCED_YOLO_CONF=0.30

# 👤 Face Recognition Margins
# Minimum similarity score to recognize a student (0.0 to 1.0)
MIN_RECOGNITION_SIM=0.65
# Below this similarity score, the person is classified as "Unknown"
UNKNOWN_THRESHOLD=0.55
# Margin between first and second highest matches to prevent false positives
SIM_MARGIN=0.15
# Number of consecutive frames a student must be matched to confirm identity
STABILITY_FRAMES=5
# Number of consecutive frames needed to boost match confidence
CONFIDENCE_BOOST_FRAMES=8

# 📊 Attendance Rules
# Minimum percentage of video duration a student must be present to be marked present (0 to 100)
ATTENDANCE_PERCENTAGE_THRESHOLD=15
# Minimum cumulative seconds a student must be present to be marked present
PRESENCE_SECONDS_THRESHOLD=5
# Standard threshold representation for frontend (0 to 100)
PRESENT_PCT_THRESHOLD=30
# Standard threshold duration for frontend (seconds)
PRESENT_SEC_THRESHOLD=10

# 📧 Email Alerts (Gmail SMTP)
# 1 = Auto-email parents/guardians when attendance falls below threshold, 0 = Disabled
AUTO_SEND_DEFAULTER_EMAILS=1
# Threshold percentage below which a student is flagged as a defaulter
DEFAULTER_ATTENDANCE_THRESHOLD=60
# Minimum number of sessions conducted before calculating defaulter eligibility
MIN_SESSIONS_FOR_DEFAULTER=2
# Gmail address used to send out the alerts
CORIS_SENDER_EMAIL=coris.attendance.system@gmail.com
# Gmail App Password (NOT your regular password. Set up via Google Account Security)
CORIS_SENDER_PASS=your_gmail_app_password_here
